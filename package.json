    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0",
