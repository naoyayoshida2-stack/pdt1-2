SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_TARGET_CHANNEL_IDS=C0123456789,C0987654321
SLACK_DIGEST_USER_ID=U0123456789

LLM_API_KEY=your-llm-api-key
LLM_MODEL=gemma3:12b
LLM_BASE_URL=

# Anthropic API（設定すると Claude で回答生成。未設定時は Ollama にフォールバック）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DIGEST_TIMEZONE=Asia/Tokyo
DIGEST_CRON=0 9 * * *
STATE_FILE_PATH=.data/state.json
STATE_RETENTION_DAYS=14
DIGEST_MAX_TOPICS=80

SYNC_OUTPUT_DIR=slack-data
SYNC_STATE_FILE_PATH=.data/sync-state.json
SYNC_RATE_LIMIT_MS=1200
